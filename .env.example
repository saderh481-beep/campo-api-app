# ── Base de datos ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host:5432/railway

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://default:pass@host:6379

# ── JWT — mismo secreto que api-web ───────────────────────────────────────────
JWT_SECRET=reemplazar_con_64_bytes_base64

# ── Cloudinary (fotos de campo y firmas) ────────────────────────────────────────
CLOUDINARY_CLOUD_NAME      = djfer9a6i
CLOUDINARY_API_KEY         = (el que aparece en API Keys)
CLOUDINARY_API_SECRET      = (el que aparece en API Keys)
CLOUDINARY_PRESET_IMAGENES = campo_imagenes
CLOUDINARY_PRESET_DOCS     = campo_docs

# ── Servidor ───────────────────────────────────────────────────────────────────
PORT=3002
NODE_ENV=development
