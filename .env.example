# API
NODE_ENV=production

PORT=3002
# En Railway normalmente no debes fijarlo manualmente.
# La plataforma inyecta PORT automaticamente.

# Base de datos (Railway)
DATABASE_URL=postgresql://${{PGUSER}}:${{POSTGRES_PASSWORD}}@${{RAILWAY_PRIVATE_DOMAIN}}:5432/${{PGDATABASE}}

# Redis (Railway)
