# API
NODE_ENV=development
PORT=3001

# Base de datos
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Redis
REDIS_URL=redis://default:PASSWORD@HOST:6379
REDIS_PUBLIC_URL=redis://default:PASSWORD@HOST:PORT

# JWT
# Genera un secreto seguro con:
# node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET=REEMPLAZA_CON_UN_SECRETO_LARGO_Y_ALEATORIO_DE_32_CARACTERES_O_MAS

# Cloudinary
CLOUDINARY_CLOUD_NAME=REEMPLAZA_CON_TU_CLOUD_NAME
CLOUDINARY_API_KEY=REEMPLAZA_CON_TU_API_KEY
CLOUDINARY_API_SECRET=REEMPLAZA_CON_TU_API_SECRET
CLOUDINARY_PRESET_IMAGENES=campo_imagenes
CLOUDINARY_PRESET_DOCS=campo_docs

# Frontend
CORS_ORIGIN=http://localhost:5173
