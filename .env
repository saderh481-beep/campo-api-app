# API
NODE_ENV=production

PORT=3002
# En Railway normalmente no debes fijarlo manualmente.
# La plataforma inyecta PORT automaticamente.

# Base de datos (Railway)
DATABASE_URL=postgresql://${{PGUSER}}:${{POSTGRES_PASSWORD}}@${{RAILWAY_PRIVATE_DOMAIN}}:5432/${{PGDATABASE}}

# Redis (Railway)
REDIS_URL=${{Redis.REDIS_URL}}

# JWT
# Genera un secreto seguro con:
# node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET=replace-with-a-long-random-secret-of-at-least-32-characters

#Envio de imagenes 
CAMPO_FILES_API_URL = https://campo-api-files-campo-saas.up.railway.app

# Frontend
CORS_ORIGIN=https://gvuzyszsflujzinykqom.supabase.co
