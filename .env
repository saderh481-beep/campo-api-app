# Base de datos
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Redis (Railway o equivalente)
REDIS_URL=redis:redis://default:PASSWORD@HOST:6379
REDIS_PUBLIC_URL=redis:redis://default:PASSWORD@PUBLIC_HOST:PORT
# JWT
# Genera un valor seguro con:
# node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET=REEMPLAZA_CON_UN_SECRETO_SEGURO

# Cloudinary
CLOUDINARY_CLOUD_NAME=REEMPLAZA_CON_TU_CLOUD_NAME
CLOUDINARY_API_KEY=REEMPLAZA_CON_TU_API_KEY
CLOUDINARY_API_SECRET=REEMPLAZA_CON_TU_API_SECRET
CLOUDINARY_PRESET_IMAGENES=campo_imagenes
CLOUDINARY_PRESET_DOCS=campo_docs

# Servidor
PORT=3002
NODE_ENV=production
