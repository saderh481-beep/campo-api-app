# API
NODE_ENV=production

# PORT
# La plataforma puede inyectarlo automaticamente.
PORT=3002

# Infraestructura
DATABASE_URL=postgresql://user:password@host:5432/database
REDIS_URL=redis://default:password@host:6379

# JWT
JWT_SECRET=replace-with-a-long-random-secret-of-at-least-32-characters

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_PRESET_IMAGENES=your-images-preset
CLOUDINARY_PRESET_DOCS=your-docs-preset

# Frontend
CORS_ORIGIN=https://tu-frontend-real.com
